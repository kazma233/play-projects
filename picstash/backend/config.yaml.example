server:
  port: 6100
  mode: debug  # debug, release
  max_body_size: 100MB  # max upload size (e.g., 10MB, 100MB, 1GB)

database:
  path: ./data/picstash.db

jwt:
  secret: change-this-to-a-random-secret-in-production
  expires_in: 24h

smtp:
  host: smtp.gmail.com
  port: 587
  username: your-email@gmail.com
  password: your-app-password
  from: noreply@picstash.app
  from_name: Picstash
  skip_tls_verify: false

# 存储配置：支持 github 或 local
storage:
  type: github  # 可选值: github, local
  path_prefix: ""  # 文件路径前缀，适用于 github 和 local 存储，如 "images" 或留空

  # GitHub 存储配置（当 type 为 github 时使用）
  github:
    token: your-github-personal-access-token
    owner: your-github-username
    repo: your-image-repo
    branch: main

  # 本地存储配置（当 type 为 local 时使用）
  local:
    base_path: ./data/files      # 文件存储根目录
    url_path: /files            # URL路径前缀
    server_addr: http://localhost:6100  # 后端服务地址（可选，默认自动推断）（如 /files）

log:
  level: debug  # debug, info, warn, error
  format: json  # json, text
  path: ./logs

auth:
  allowed_emails:
    - admin@example.com
    - another@example.com
  home_auth: true  # true表示需要登录才能查看首页，默认false
